---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	...(heroImage && { "image": new URL(heroImage.src, Astro.site || 'https://nealmcspadden.com').toString() }),
	"author": {
		"@type": "Person",
		"name": "Neal McSpadden",
		"url": "https://nealmcspadden.com/about/"
	},
	"publisher": {
		"@type": "Organization",
		"name": "Neal McSpadden",
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/favicon.ico', Astro.site || 'https://nealmcspadden.com').toString()
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": new URL(Astro.url.pathname, Astro.site || 'https://nealmcspadden.com').toString()
	}
};

const webpageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": new URL(Astro.url.pathname, Astro.site || 'https://nealmcspadden.com').toString(),
	"name": title,
	"description": description,
	"speakable": {
		"@type": "SpeakableSpecification",
		"cssSelector": [".aeo-speakable-title", ".aeo-speakable-bluf"]
	}
};

const jsonLdGraph = {
	"@context": "https://schema.org",
	"@graph": [articleSchema, webpageSchema]
};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
	</head>

	<body>
		<Header />
		<main class="post-layout">
			<article class="post-article">
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} src={heroImage} alt="" class="hero-img-element" />
					</div>
				)}
				<div class="prose">
					<header class="title-header">
						<div class="date-container">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated-on">
									(Updated <FormattedDate date={updatedDate} />)
								</span>
							)}
						</div>
						<h1 class="aeo-speakable-title">{title}</h1>
						<p class="description-tagline aeo-speakable-bluf">{description}</p>
						<hr />
					</header>
					<div class="post-content">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-layout {
		width: var(--max-width-content);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 3rem 1rem;
	}
	
	.post-article {
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		overflow: hidden;
		box-shadow: var(--box-shadow-md);
	}
	
	.hero-image {
		width: 100%;
		border-bottom: 1px solid var(--border-color);
	}
	.hero-img-element {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
		border: none;
	}
	
	.prose {
		padding: 3rem;
		color: var(--text-secondary);
	}
	
	.title-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}
	
	.title-header h1 {
		margin-top: 0.5rem;
		margin-bottom: 0.75rem;
		font-size: 2.5rem;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		line-height: 1.2;
	}
	
	.description-tagline {
		font-size: 1.1rem;
		color: var(--text-muted);
		line-height: 1.5;
		margin-top: 0.5rem;
		margin-bottom: 1.5rem;
		font-style: italic;
	}
	
	.date-container {
		font-family: monospace;
		font-size: 0.85rem;
		color: var(--accent-blue);
		font-weight: 600;
	}
	
	.last-updated-on {
		color: var(--text-muted);
		margin-left: 0.5rem;
	}
	
	hr {
		border-color: var(--border-color);
		margin: 2rem auto 0 auto;
		width: 100px;
		border-width: 2px;
		border-style: solid;
	}
	
	/* Style deep elements inside slot */
	.post-content :global(p) {
		margin-bottom: 1.75rem;
		line-height: 1.8;
	}
	
	.post-content :global(h2) {
		font-size: 1.6rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}
	
	.post-content :global(h3) {
		font-size: 1.3rem;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.post-content :global(ul), .post-content :global(ol) {
		margin-bottom: 1.75rem;
		padding-left: 1.5rem;
	}

	.post-content :global(li) {
		margin-bottom: 0.5rem;
		line-height: 1.8;
	}

	.post-content :global(blockquote) {
		margin: 2rem 0;
	}

	@media (max-width: 768px) {
		.prose {
			padding: 1.5rem;
		}
		.title-header h1 {
			font-size: 1.85rem;
		}
		.post-layout {
			padding: 1.5rem 0.5rem;
		}
	}
</style>
