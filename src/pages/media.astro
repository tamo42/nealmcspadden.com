---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Media & Citations | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Media & Citations</h1>
			<p>
				Podcasts, articles, and external publications featuring my frameworks and operating models.
			</p>
			<!-- Media list will be dynamically populated here -->
		</main>
		<Footer />
	</body>
</html>
