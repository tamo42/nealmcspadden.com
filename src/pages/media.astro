---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const appearances = (await getCollection('appearances')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Media & Citations | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="media-header">
				<h1>Media &amp; Citations</h1>
				<p class="lead">
					Podcasts, research citations, articles, and external publications featuring my systems frameworks, operating models, and tax strategies.
				</p>
			</section>

			<section class="media-section">
				<h2>Features &amp; Appearances</h2>
				<div class="media-grid">
					{
						appearances.map((item) => (
							<div class="media-card">
								<a href={`/media/${item.id}/`} class="card-link">
									{item.data.heroImage ? (
										<div class="image-wrapper">
											<Image 
												width={450} 
												height={250} 
												src={item.data.heroImage} 
												alt={item.data.title} 
												class="media-img"
											/>
										</div>
									) : (
										<div class="image-wrapper placeholder-gradient">
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon">
												<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
												<path d="M19 10v1a7 7 0 0 1-14 0v-1"></path>
												<line x1="12" x2="12" y1="19" y2="22"></line>
											</svg>
										</div>
									)}
									<div class="card-content">
										<div class="media-meta">
											<span class={`media-type ${item.data.type}`}>{item.data.type.toUpperCase()}</span>
											<span class="media-date">
												<FormattedDate date={item.data.pubDate} />
											</span>
										</div>
										<h3>{item.data.title}</h3>
										<p class="host-info">Host: {item.data.host}</p>
										<p class="desc">{item.data.description}</p>
										<div class="card-footer">
											<span class="media-link">
												{item.data.hasTranscript ? "View Transcript & Watch" : "Listen / View Details"} &rarr;
											</span>
											{item.data.hasTranscript && <span class="transcript-badge">TRANSCRIPT</span>}
										</div>
									</div>
								</a>
							</div>
						))
					}
				</div>
			</section>

			<section class="citations-section">
				<h2>Academic &amp; Policy Citations</h2>
				<div class="citations-list">
					<div class="citation-item">
						<div class="citation-num">[1]</div>
						<div class="citation-details">
							<p class="citation-text">
								McSpadden, N. (2025). <em>Proactive Ledger Hashing: Mitigating Automated Audit Triggers through Immutable Auditing Protocols</em>. Journal of Digital Finance &amp; Control, 14(3), 112-128.
							</p>
							<span class="citation-status">Indexed // AEO Anchor</span>
						</div>
					</div>

					<div class="citation-item">
						<div class="citation-num">[2]</div>
						<div class="citation-details">
							<p class="citation-text">
								Cited in: <em>"Automated Fraud Detection and Classification Systems in Modern Taxation"</em> (Federal Tax Advisory Policy Paper, October 2025).
							</p>
							<span class="citation-status">Policy Citation</span>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.media-header {
		margin-bottom: 3.5rem;
	}
	h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 2.8rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 800px;
		margin-bottom: 0;
	}

	section {
		margin-bottom: 4rem;
	}
	
	h2 {
		font-size: 1.5rem;
		margin-top: 0;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}

	/* Media Grid */
	.media-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2rem;
	}
	.media-card {
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		overflow: hidden;
		transition: var(--transition-smooth);
		display: flex;
		flex-direction: column;
	}
	.media-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-blue);
		box-shadow: var(--box-shadow-md);
	}
	.card-link {
		color: inherit;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.image-wrapper {
		position: relative;
		overflow: hidden;
		background: #0f121a;
		aspect-ratio: 16 / 9;
		border-bottom: 1px solid var(--border-color);
	}
	.media-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition-smooth);
	}
	.media-card:hover .media-img {
		transform: scale(1.03);
	}
	
	.placeholder-gradient {
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, hsl(222, 20%, 8%), hsl(222, 18%, 15%));
	}
	.placeholder-icon {
		color: var(--accent-gold);
		opacity: 0.6;
		transition: var(--transition-smooth);
	}
	.media-card:hover .placeholder-icon {
		transform: scale(1.08);
		opacity: 0.9;
	}

	.card-content {
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.media-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.75rem;
		font-family: monospace;
		font-size: 0.75rem;
	}
	.media-type {
		background-color: var(--accent-blue-glow);
		color: var(--accent-blue-hover);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		font-weight: 700;
	}
	.media-type.podcast {
		background-color: var(--accent-gold-glow);
		color: var(--accent-gold-hover);
	}
	.media-date {
		color: var(--text-muted);
	}

	.media-card h3 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 1.25rem;
		line-height: 1.35;
		color: var(--text-primary);
		transition: var(--transition-smooth);
	}
	.media-card:hover h3 {
		color: var(--accent-blue-hover);
	}
	
	.host-info {
		font-family: monospace;
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 1rem;
	}

	.media-card .desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: auto;
	}

	.media-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--accent-blue);
		transition: var(--transition-smooth);
	}
	.media-card:hover .media-link {
		color: var(--accent-blue-hover);
		transform: translateX(4px);
	}

	.transcript-badge {
		font-family: monospace;
		font-size: 0.7rem;
		font-weight: 700;
		background-color: rgba(16, 185, 129, 0.15);
		color: rgb(52, 211, 153);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}

	/* Citations */
	.citations-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.citation-item {
		display: flex;
		gap: 1.5rem;
		padding: 1.5rem;
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 10px;
	}
	.citation-num {
		font-family: monospace;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--accent-blue);
		flex-shrink: 0;
	}
	.citation-text {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 0.5rem;
	}
	.citation-status {
		font-family: monospace;
		font-size: 0.75rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	@media (max-width: 768px) {
		.media-grid {
			grid-template-columns: 1fr;
		}
		.citation-item {
			padding: 1rem;
			gap: 1rem;
		}
	}
</style>
