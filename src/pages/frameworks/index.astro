---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Frameworks | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Frameworks</h1>
			<p>
				High-effort, thought-leading pieces and operational contexts on how to build and scale.
			</p>
			<!-- Framework list will be dynamically populated here -->
		</main>
		<Footer />
	</body>
</html>
