---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Frameworks | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="frameworks-header">
				<h1>Frameworks</h1>
				<p class="lead">
					High-effort, systems-level operational contexts and strategic blueprints on how to build, scale, and insulate assets.
				</p>
			</section>

			<div class="frameworks-list">
				<div class="framework-card">
					<a href="/frameworks/audit-by-ai">
						<div class="framework-content">
							<div class="meta-tag">OPERATIONAL CONTEXT // COGNITIVE SHIFT</div>
							<h2>The Audit by AI Era</h2>
							<p class="desc">A technical blueprint detailing how to structure real-time automated financial controls and defensive ledgers to mitigate machine-learning IRS audits.</p>
							<span class="read-more">Read Operational Context &rarr;</span>
						</div>
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.frameworks-header {
		margin-bottom: 3.5rem;
	}
	h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 2.8rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 800px;
		margin-bottom: 0;
	}
	
	.frameworks-list {
		margin-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}
	
	.framework-card {
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		transition: var(--transition-smooth);
		overflow: hidden;
	}
	.framework-card a {
		display: block;
		padding: 2.5rem;
		color: inherit;
		text-decoration: none;
	}
	.framework-card:hover {
		border-color: var(--accent-blue);
		transform: translateY(-3px);
		box-shadow: var(--box-shadow-md), 0 0 25px var(--accent-blue-glow);
	}
	.framework-card .meta-tag {
		font-family: monospace;
		font-size: 0.75rem;
		color: var(--accent-blue);
		font-weight: 700;
		letter-spacing: 0.1em;
		margin-bottom: 0.75rem;
	}
	.framework-card h2 {
		margin-top: 0;
		margin-bottom: 0.75rem;
		font-size: 1.6rem;
		border-bottom: none;
		padding-bottom: 0;
		transition: var(--transition-smooth);
	}
	.framework-card:hover h2 {
		color: var(--accent-blue-hover);
	}
	.framework-card .desc {
		color: var(--text-secondary);
		margin-bottom: 1.5rem;
		max-width: 750px;
		line-height: 1.7;
	}
	.framework-card .read-more {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--accent-blue);
		display: inline-flex;
		align-items: center;
		transition: var(--transition-smooth);
	}
	.framework-card:hover .read-more {
		color: var(--accent-blue-hover);
		transform: translateX(5px);
	}
</style>
