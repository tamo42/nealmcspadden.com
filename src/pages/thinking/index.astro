---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Thinking | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="thinking-header">
				<h1>Thinking</h1>
				<p class="lead">Essays, frameworks, and raw insights on systems architecture, tax control, and business scaling.</p>
			</section>

			<section class="posts-section">
				<div class="posts-grid">
					{
						posts.map((post, idx) => (
							<div class={idx === 0 ? "post-card featured" : "post-card"}>
								<a href={`/thinking/${post.slug}/`}>
									{post.data.heroImage && (
										<div class="image-wrapper">
											<Image 
												width={idx === 0 ? 960 : 450} 
												height={idx === 0 ? 480 : 250} 
												src={post.data.heroImage} 
												alt="" 
												class="post-img"
											/>
										</div>
									)}
									<div class="post-info">
										<div class="meta">
											{idx === 0 && <span class="featured-badge">FEATURED ESSAY</span>}
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h2 class="title">{post.data.title}</h2>
										<p class="desc">{post.data.description}</p>
										<span class="read-link">Read Essay &rarr;</span>
									</div>
								</a>
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.thinking-header {
		margin-bottom: 3.5rem;
	}
	h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 2.8rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 800px;
		margin-bottom: 0;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}
	
	.post-card {
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		overflow: hidden;
		transition: var(--transition-smooth);
		display: flex;
		flex-direction: column;
	}
	
	.post-card a {
		color: inherit;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	
	.post-card.featured {
		grid-column: 1 / -1;
	}
	
	.post-card.featured a {
		flex-direction: row;
	}
	
	@media (max-width: 850px) {
		.post-card.featured a {
			flex-direction: column;
		}
	}
	
	.image-wrapper {
		position: relative;
		overflow: hidden;
		background: #0f121a;
	}
	
	.post-card.featured .image-wrapper {
		flex: 1 1 50%;
		border-right: 1px solid var(--border-color);
	}
	
	.post-card.featured .post-info {
		flex: 1 1 50%;
		padding: 2.5rem;
	}
	
	.post-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition-smooth);
	}
	
	.post-card:hover .post-img {
		transform: scale(1.03);
	}
	
	.post-info {
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}
	
	.meta {
		font-family: monospace;
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	
	.featured-badge {
		color: var(--accent-blue);
		background-color: var(--accent-blue-glow);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		font-weight: 700;
		font-size: 0.7rem;
	}
	
	.title {
		font-size: 1.4rem;
		margin-top: 0;
		margin-bottom: 0.75rem;
		color: var(--text-primary);
		line-height: 1.3;
		border-bottom: none;
		padding-bottom: 0;
		transition: var(--transition-smooth);
	}
	
	.post-card.featured .title {
		font-size: 1.85rem;
	}
	
	.post-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-blue);
		box-shadow: var(--box-shadow-md);
	}
	
	.post-card:hover .title {
		color: var(--accent-blue-hover);
	}
	
	.desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}
	
	.read-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--accent-blue);
		margin-top: auto;
		transition: var(--transition-smooth);
	}
	
	.post-card:hover .read-link {
		color: var(--accent-blue-hover);
		transform: translateX(4px);
	}

	@media (max-width: 768px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
		.post-card.featured {
			grid-column: span 1;
		}
		.post-card.featured .post-info {
			padding: 1.5rem;
		}
	}
</style>
