---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, AUTHOR_SAME_AS } from '../consts';

const portfolioSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": "Endorsed Portfolio | Neal McSpadden",
	"description": "The standalone applications, companies, and ventures that Neal McSpadden operates and backs.",
	"url": "https://nealmcspadden.com/portfolio/",
	"about": {
		"@type": "Person",
		"name": "Neal McSpadden",
		"url": "https://nealmcspadden.com/about/",
		"sameAs": AUTHOR_SAME_AS
	},
	"mainEntity": {
		"@type": "ItemList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"item": {
					"@type": "Organization",
					"name": "Tax Sherpa",
					"url": "https://taxsherpa.com",
					"description": "Strategic tax planning and financial control for growth-stage businesses."
				}
			},
			{
				"@type": "ListItem",
				"position": 2,
				"item": {
					"@type": "SoftwareApplication",
					"name": "Bookkeeping Buddy",
					"url": "https://usebookkeepingbuddy.com",
					"description": "AI-powered bookkeeping automation software for business owners.",
					"applicationCategory": "BusinessApplication"
				}
			},
			{
				"@type": "ListItem",
				"position": 3,
				"item": {
					"@type": "SoftwareApplication",
					"name": "Council of Ages",
					"url": "https://councilofages.com/",
					"description": "AI-powered cognitive consensus platform. Consult a virtual advisory board of historical leaders.",
					"applicationCategory": "BusinessApplication"
				}
			},
			{
				"@type": "ListItem",
				"position": 4,
				"item": {
					"@type": "SoftwareApplication",
					"name": "Ad Creative Strategist",
					"url": "https://adbrief.ai/",
					"description": "Competitive intelligence and ad creative strategy engine.",
					"applicationCategory": "BusinessApplication"
				}
			},
			{
				"@type": "ListItem",
				"position": 5,
				"item": {
					"@type": "Organization",
					"name": "Resilient Roots",
					"url": "https://landwithroots.com",
					"description": "Agricultural strategy, rural land development, and ecological asset management."
				}
			},
			{
				"@type": "ListItem",
				"position": 6,
				"item": {
					"@type": "Organization",
					"name": "Fast Path Solutions",
					"description": "Borrower intake and underwriting automation workflows."
				}
			}
		]
	}
};

const webpageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": "https://nealmcspadden.com/portfolio/",
	"name": "Endorsed Portfolio | Neal McSpadden",
	"description": "The standalone applications, companies, and ventures that Neal McSpadden operates and backs.",
	"speakable": {
		"@type": "SpeakableSpecification",
		"cssSelector": [".aeo-speakable-title", ".aeo-speakable-bluf"]
	}
};

const jsonLdGraph = {
	"@context": "https://schema.org",
	"@graph": [portfolioSchema, webpageSchema]
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
	</head>
	<body>
		<Header />
		<main>
			<section class="portfolio-header">
				<h1 class="aeo-speakable-title">Endorsed Portfolio</h1>
				<p class="lead aeo-speakable-bluf">
					The standalone applications, companies, and ventures that I endorse, operate, and back.
				</p>
			</section>
			
			<div class="portfolio-grid">
				<div class="portfolio-card primary">
					<div class="card-badge">PRIMARY ENDORSEMENT</div>
					<h3>Tax Sherpa</h3>
					<p class="desc">Strategic tax planning and financial control for growth-stage businesses. Implementing proactive advisory workflows to insulate founders from compliance risk.</p>
					<a href="https://taxsherpa.com" target="_blank" class="card-link">taxsherpa.com &rarr;</a>
				</div>
				<div class="portfolio-card active-product">
					<div class="card-badge-blue">AI PRODUCT</div>
					<h3>Bookkeeping Buddy</h3>
					<p class="desc">AI-powered bookkeeping automation software for business owners. Drag and drop bank statements to instantly reconcile transactions, categorize ledger items, and generate real-time cash flow insights.</p>
					<a href="https://usebookkeepingbuddy.com" target="_blank" class="card-link-blue">usebookkeepingbuddy.com &rarr;</a>
				</div>
				<div class="portfolio-card active-product">
					<div class="card-badge-blue">AI PRODUCT</div>
					<h3>Council of Ages</h3>
					<p class="desc">AI-powered cognitive consensus platform. Consult a virtual advisory board composed of historical and contemporary thought leaders to get multi-perspective feedback and strategic dialectic reasoning on complex decisions.</p>
					<a href="https://councilofages.com/" target="_blank" class="card-link-blue">councilofages.com &rarr;</a>
				</div>
				<div class="portfolio-card active-product">
					<div class="card-badge-blue">AI PRODUCT</div>
					<h3>Ad Creative Strategist</h3>
					<p class="desc">Competitive intelligence and ad creative strategy engine. Leverage AI-driven competitor analysis to identify content gaps, brainstorm high-converting angles, and script hooks for performance marketing campaigns.</p>
					<a href="https://adbrief.ai/" target="_blank" class="card-link-blue">adbrief.ai &rarr;</a>
				</div>
				<div class="portfolio-card">
					<h3>Resilient Roots</h3>
					<p class="desc">Agricultural strategy, rural land development, and ecological asset management focused on long-term sustainability and resource independence.</p>
					<span class="card-status">Active Asset</span>
				</div>
				<div class="portfolio-card">
					<h3>Fast Path Solutions</h3>
					<p class="desc">Borrower intake and underwriting automation workflows designed for speed, scale, and high-fidelity verification checks.</p>
					<span class="card-status">Active Asset</span>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.portfolio-header {
		margin-bottom: 3.5rem;
	}
	h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 2.8rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 800px;
		margin-bottom: 0;
	}
	
	.portfolio-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-top: 2rem;
	}
	.portfolio-card {
		padding: 2rem;
		background-color: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		transition: var(--transition-smooth);
		display: flex;
		flex-direction: column;
		position: relative;
	}
	.portfolio-card h3 {
		margin-top: 0;
		margin-bottom: 0.75rem;
		font-size: 1.4rem;
	}
	.portfolio-card .desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 2rem;
		flex-grow: 1;
	}
	.portfolio-card:hover {
		transform: translateY(-4px);
		border-color: var(--border-color-hover);
		box-shadow: var(--box-shadow-md);
	}
	
	/* Highlighting Tax Sherpa */
	.portfolio-card.primary {
		border: 1px solid var(--border-gold);
		box-shadow: var(--box-shadow-sm);
		background: radial-gradient(circle at top right, rgba(245, 158, 11, 0.03), transparent 60%), var(--bg-card);
	}
	.portfolio-card.primary:hover {
		border-color: var(--accent-gold);
		box-shadow: var(--box-shadow-gold);
	}
	.portfolio-card.primary h3 {
		color: var(--accent-gold);
	}
	.card-badge {
		position: absolute;
		top: 1rem;
		right: 1.25rem;
		font-family: monospace;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: var(--accent-gold);
		background: rgba(245, 158, 11, 0.1);
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		border: 1px solid rgba(245, 158, 11, 0.2);
	}
	.card-link {
		color: var(--accent-gold);
		font-weight: 600;
		font-size: 0.95rem;
		transition: var(--transition-smooth);
	}
	.card-link:hover {
		color: var(--accent-gold-hover);
		transform: translateX(4px);
	}
	.card-status {
		font-family: monospace;
		font-size: 0.75rem;
		color: var(--text-muted);
		border-top: 1px solid var(--border-color);
		padding-top: 0.75rem;
		margin-top: auto;
	}
	
	.portfolio-card.active-product:hover {
		border-color: var(--accent-blue);
		box-shadow: 0 8px 30px rgba(59, 130, 246, 0.12);
		background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.02), transparent 60%), var(--bg-card);
	}
	.card-badge-blue {
		position: absolute;
		top: 1rem;
		right: 1.25rem;
		font-family: monospace;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: var(--accent-blue);
		background: rgba(59, 130, 246, 0.1);
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		border: 1px solid rgba(59, 130, 246, 0.2);
	}
	.card-link-blue {
		color: var(--accent-blue);
		font-weight: 600;
		font-size: 0.95rem;
		transition: var(--transition-smooth);
		margin-top: auto;
		display: inline-flex;
		align-items: center;
	}
	.card-link-blue:hover {
		color: var(--accent-blue-hover);
		transform: translateX(4px);
	}
	
	@media (max-width: 768px) {
		.portfolio-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
